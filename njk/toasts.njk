            <div class="row g-2">
               <div class="col-12">
                  <button class="btn btn-primary" data-toggle="toast" data-target="#toastTopLeft">Top
                     Left</button>
                  <button class="btn btn-primary" data-toggle="toast" data-target="#toastTopCenter">Top
                     Center</button>
                  <button class="btn btn-primary" data-toggle="toast" data-target="#toastTopRight">Top
                     Right</button>
               </div>
