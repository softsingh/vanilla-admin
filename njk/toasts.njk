{% set file_name = "toasts" %}
{% extends "_dash_base.njk" %}
{% block title %}
Toasts
{% endblock title %}
{% block content %}
<div class="row g-6">
   <div class="col-12 col-md-6">
      <div class="card">
         <div class="card-header pb-0">
            <h5>Default</h5>
         </div>
         <div class="card-body">
            <button class="btn btn-primary" id="btnShowToast">Show Toast</button>
         </div>
      </div>
      <div class="toast" id="defaultToast">
         <div class="toast-header">
            <strong class="me-auto">Default Toast</strong>
            <button type="button" class="btn-close"></button>
         </div>
         <div class="toast-body">
            This is a default toast
         </div>
      </div>
   </div>
   <div class="col-12 col-md-6">
      <div class="card">
         <div class="card-header pb-0">
            <h5>Default</h5>
         </div>
         <div class="card-body">
            <div class="toast-container">
               <div class="toast show" id="defaultToast">
                  <div class="toast-header">
                     <strong class="me-auto">Default Toast</strong>
                     <button type="button" class="btn-close"></button>
                  </div>
                  <div class="toast-body">
                     This is a default toast
                  </div>
               </div>
            </div>
         </div>
      </div>
   </div>
</div>
{% endblock content %}